# ─── SEDSP Frontend Environment ───
# Copy: cp .env.example .env  (hoặc npm run setup)

# Mock mode (mặc định) — không cần backend
VITE_USE_MOCK=true

# Khi backend Spring Boot sẵn sàng:
# VITE_USE_MOCK=false

# REST prefix — Vite proxy /api → backend
VITE_API_BASE_URL=/api

# Backend origin (Swagger, health check)
VITE_BACKEND_ORIGIN=http://localhost:8080
