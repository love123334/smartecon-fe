# ─── SEDSP Frontend Environment ───
# Copy: cp .env.example .env  (hoặc npm run setup)

# Mock toàn bộ UI (không cần backend)
# VITE_USE_MOCK=true

# Hybrid: auth, products, categories, cart, orders, inventory, admin users từ Spring Boot
VITE_USE_MOCK=false

# REST prefix — Vite proxy /api → http://localhost:8080
VITE_API_BASE_URL=/api/v1

# Backend origin (Swagger)
VITE_BACKEND_ORIGIN=http://localhost:8080
